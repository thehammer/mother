#!/usr/bin/env bash

# --- mother plugin path resolver (prepended during port) ---
# Resolves symlinks so the plugin works when installed via `ln -s` into a bin dir.
_MOTHER_RAW="${BASH_SOURCE[0]}"
while [ -L "$_MOTHER_RAW" ]; do
    _link="$(readlink "$_MOTHER_RAW")"
    case "$_link" in
        /*) _MOTHER_RAW="$_link" ;;
        *)  _MOTHER_RAW="$(dirname "$_MOTHER_RAW")/$_link" ;;
    esac
done
_MOTHER_SELF="$(cd "$(dirname "$_MOTHER_RAW")" && pwd -P)"
: "${MOTHER_BIN_DIR:=$_MOTHER_SELF}"
: "${MOTHER_LIB_DIR:=$_MOTHER_SELF/../lib}"
# -----------------------------------------------------------

# mother-run-job — run a single queued job to completion.
#
# Invoked by `mother run --once` (phase 1). In phase 2 the daemon calls this
# the same way. Responsibilities:
#   - Resolve the target working directory (worktree or main dir).
#   - Acquire a workspace lock if isolation=main-dir.
#   - Spawn `claude --agent <worker_agent> -p "$(cat <plan>)"` as a headless
#     background process (nohup + disown) at that cwd, tee'd to the job log.
#     The worker agent defaults to `cody` if the user has one in
#     $work_dir/.claude/agents/ or ~/.claude/agents/ (so personal
#     customizations win), falling back to the plugin-shipped `mother:cody`
#     for fresh installs. Override either way via MOTHER_WORKER_AGENT.
#     The pid is recorded on the job as `worker_pid`.
#   - Poll a status-marker file; transition the job on exit.
#   - On cancellation: SIGTERM the worker, wait 10s, then SIGKILL.
#   - Parse the log for a PR URL and cost info (best-effort).
#
# Blocks until the job exits. Usage: mother-run-job <job-id>

set -u

MOTHER_ROOT="${MOTHER_ROOT:-${MOTHER_ROOT:-$HOME/.mother}}"
JOBS_DIR="$MOTHER_ROOT/jobs"
EVENTS_DIR="$MOTHER_ROOT/events"
LOGS_DIR="$MOTHER_ROOT/logs"
RUNNER_DIR="$MOTHER_ROOT/runner"

id="${1:?usage: mother-run-job <id>}"
job_file="$JOBS_DIR/$id.json"
[ -f "$job_file" ] || { echo "mother-run-job: no such job: $id" >&2; exit 1; }

# shellcheck source=/dev/null
source "$MOTHER_LIB_DIR/worktree.sh"
# shellcheck source=/dev/null
source "$MOTHER_LIB_DIR/locks.sh"

mother_cli="$MOTHER_BIN_DIR/mother"

iso_now() { date -u +%Y-%m-%dT%H:%M:%SZ; }
_atomic_write() {
    # NB: `path` collides with zsh's special array for PATH — use _target.
    local _target="$1" content="$2" tmp="${1}.tmp.$$"
    printf '%s' "$content" > "$tmp" && mv "$tmp" "$_target"
}
_with_lock() {
    local target="$1"; shift
    local lockdir="${target}.lockdir"
    local tries=0
    while ! mkdir "$lockdir" 2>/dev/null; do
        sleep 0.05
        tries=$((tries + 1))
        [ "$tries" -gt 200 ] && { echo "mother-run-job: could not acquire lock for $target after 10s" >&2; return 1; }
    done
    "$@"
    local rc=$?
    rmdir "$lockdir" 2>/dev/null || true
    return $rc
}
_append_line() { printf '%s\n' "$2" >> "$1"; }
_append_event() {
    local kind="$1" detail="${2:-}"
    [ -z "$detail" ] && detail='{}'
    local ev _eventpath
    ev=$(jq -nc --arg ts "$(iso_now)" --arg kind "$kind" --argjson detail "$detail" \
        '{ts: $ts, kind: $kind, detail: $detail}')
    _eventpath="$EVENTS_DIR/$id.jsonl"
    _with_lock "$_eventpath" _append_line "$_eventpath" "$ev"
}
_job_update() {
    local filter="$1"
    local merged; merged=$(jq "$filter" "$job_file") || return 1
    _atomic_write "$job_file" "$merged"
}
_transition() {
    local new="$1" detail="${2:-}"
    [ -z "$detail" ] && detail='{}'
    _job_update ".state = \"$new\""
    case "$new" in
        running)    _job_update ".started_at = \"$(iso_now)\"" ;;
        succeeded|failed|cancelled)
                    _job_update ".finished_at = \"$(iso_now)\"" ;;
    esac
    _append_event "$new" "$detail"
}

# Safety net: if we die before reaching a clean terminal transition (lock
# acquisition failure under set -u, missing tool, killed by signal, etc.),
# mark the job `failed: runner_died_early` so it doesn't linger as a zombie.
# The trap is a no-op once the job has already been transitioned to a
# terminal state — it only fires if the state is still `running` at exit.
# Cleared explicitly at the end of a normal run.
_runner_died_trap() {
    local rc=$?
    local cur; cur=$(jq -r '.state // empty' "$job_file" 2>/dev/null)
    if [ "$cur" = "running" ]; then
        _transition failed "$(jq -nc --argjson rc "$rc" \
            '{reason: "runner_died_early", exit_code: $rc}')" 2>/dev/null || true
    fi
}
trap _runner_died_trap EXIT

# Accept ready (invoked by `mother run --once`) or running (daemon already
# pre-transitioned before forking us).
state=$(jq -r .state "$job_file")
case "$state" in
    ready|running) ;;
    *) echo "mother-run-job: job $id is $state, expected ready or running" >&2; exit 1 ;;
esac

isolation=$(jq -r .isolation  "$job_file")
branch=$(jq -r .branch        "$job_file")
repo_path=$(jq -r .repo_path  "$job_file")
plan_path=$(jq -r .plan_path  "$job_file")
log_path=$(jq -r .log_path    "$job_file")
base_ref=$(jq -r .base_ref    "$job_file")
repo=$(jq -r .repo            "$job_file")

# Resolve working directory.
work_dir=""
if [ "$isolation" = "worktree" ]; then
    (cd "$repo_path" && git fetch --quiet origin "${base_ref#origin/}" 2>/dev/null || true)
    # Create the branch + worktree from base_ref.
    wt_path=$(cd "$repo_path" && source "$MOTHER_LIB_DIR/worktree.sh" && worktree_get_path "$branch")
    if [ ! -d "$wt_path" ]; then
        (cd "$repo_path" && git worktree add -b "$branch" "$wt_path" "$base_ref") \
            || { _transition failed "$(jq -nc --arg r "worktree_create_failed" '{reason: $r}')"; exit 1; }
    fi
    work_dir="$wt_path"
else
    # main-dir: acquire workspace lock so concurrent main-dir jobs serialize.
    lock_name="${repo}:workspace"
    if ! lock_acquire "$lock_name" 0 >/dev/null 2>&1; then
        echo "mother-run-job: could not acquire lock $lock_name (another main-dir job is running)" >&2
        _transition failed "$(jq -nc --arg r "lock_busy" --arg lock "$lock_name" '{reason: $r, lock: $lock}')"
        exit 1
    fi
    work_dir="$repo_path"
fi

# Persist resolved work_dir on the job JSON so peek (and similar consumers)
# can read it without re-deriving from repo_path/branch/isolation.
_job_update ".work_dir = \"$work_dir\""

# Record the resolved work_dir on the job. If we were started from `ready`
# (via `mother run --once`), also emit the running transition; if the daemon
# pre-transitioned us, just append a started event. The actual worker process
# is spawned further down, after the wrapper script is written; the
# `worker_pid` is recorded at that point.
if [ "$state" = "ready" ]; then
    _transition running "$(jq -nc --arg d "$work_dir" '{work_dir: $d}')"
else
    _append_event "started" "$(jq -nc --arg d "$work_dir" '{work_dir: $d}')"
fi

# Spawn claude in a headless background process. Use a wrapper script so we
# can capture exit status and keep quoting sane.
#
# Worker agent resolution, in priority order:
#   1. MOTHER_WORKER_AGENT, if set — honored absolutely. Permanent overrides
#      belong in the launchd plist's EnvironmentVariables block.
#   2. Plain `cody`, if the user has one in the project's
#      $work_dir/.claude/agents/cody.md or their global
#      ~/.claude/agents/cody.md — their personal customizations beat our
#      shipped defaults.
#   3. `mother:cody` — the plugin-shipped fallback that works out-of-the-box
#      on fresh installs. Claude Code namespaces plugin-shipped agents with
#      the plugin's name.
if [ -n "${MOTHER_WORKER_AGENT:-}" ]; then
    worker_agent="$MOTHER_WORKER_AGENT"
elif [ -f "$work_dir/.claude/agents/cody.md" ] || [ -f "$HOME/.claude/agents/cody.md" ]; then
    worker_agent="cody"
else
    worker_agent="mother:cody"
fi

# Generate a deterministic session ID and pass it to claude via --session-id
# so the transcript filename is predictable. Without this, main-dir jobs
# sharing a work_dir all land in the same ~/.claude/projects/<slug>/ and
# `mother peek` can't tell them apart — it falls back to newest-mtime,
# which conflates sibling workers and any user's foreground Claude session
# in the same directory.
session_id=$(uuidgen 2>/dev/null | tr 'A-Z' 'a-z')
if [ -z "$session_id" ] && [ -r /proc/sys/kernel/random/uuid ]; then
    session_id=$(cat /proc/sys/kernel/random/uuid)
fi
if [ -n "$session_id" ]; then
    _job_update ".session_id = \"$session_id\""
fi

# Compose the spawn-time prompt. The on-disk plan file stays the user's
# authored content; everything Mother adds (the await/resume capability
# preamble, plus any resume context from a previous pause cycle) is
# layered in at spawn time and written to a single $RUNNER_DIR/$id.prompt.md
# that becomes the prompt claude actually receives.
#
#   [preamble]              ← from $MOTHER_PREAMBLE_PATH or the shipped
#                             template; tells the agent how to call
#                             `mother await`. Empty / disabled by pointing
#                             MOTHER_PREAMBLE_PATH at /dev/null or a
#                             missing file.
#   [resume context]        ← only on resume cycles: previous question,
#                             operator's answer, worktree-state heads-up.
#   [user's plan]           ← exact contents of $plan_path, untouched.
#
# We don't try to resume the previous claude session (no --resume in -p
# mode); the augmented prompt + the worktree itself (which still carries
# the in-progress changes from before the pause) are how continuity is
# preserved.

spawn_prompt="$RUNNER_DIR/$id.prompt.md"
preamble_path="${MOTHER_PREAMBLE_PATH:-$MOTHER_LIB_DIR/../templates/preamble.md}"
pending_answer=$(jq -r '.pending_answer // empty' "$job_file" 2>/dev/null || echo "")
prev_question=$(jq -r '.question // empty'       "$job_file" 2>/dev/null || echo "")

{
    if [ -r "$preamble_path" ] && [ -s "$preamble_path" ]; then
        cat "$preamble_path"
        printf '\n---\n\n'
    fi

    if [ -n "$pending_answer" ]; then
        printf '# Resumed plan — operator answered your question\n\n'
        printf 'A previous worker on this job paused itself with `mother await`.\n'
        printf 'The operator has answered. Pick up from where the prior worker left off.\n\n'
        printf '## The question you (or your predecessor) asked\n\n'
        if [ -n "$prev_question" ]; then
            printf '%s\n\n' "$prev_question"
        else
            printf '_(no question recorded — this should not happen; proceed with the answer below as guidance)_\n\n'
        fi
        printf "## The operator's answer\n\n"
        printf '%s\n\n' "$pending_answer"
        printf '## Worktree state at pause time\n\n'
        printf 'Your work directory at `%s` retains all changes and commits from the\n' "$work_dir"
        printf 'previous run — your branch is `%s`. Run `git status` and `git log --oneline`\n' "$branch"
        printf 'before resuming so you orient yourself in the in-progress work.\n\n'
        printf '## Original plan (for reference)\n\n'
    fi

    cat "$plan_path"
} > "$spawn_prompt"
resolved_plan_path="$spawn_prompt"

if [ -n "$pending_answer" ]; then
    # Consume the answer + question so the next spawn (if any) starts clean.
    # Keep resumed_at / resume_count for the audit trail.
    merged=$(jq '.pending_answer = null | .question = null' "$job_file") \
        && _atomic_write "$job_file" "$merged"
    _append_event "resumed_from_input" \
        "$(jq -nc --arg q "$prev_question" --arg a "$pending_answer" --arg p "$spawn_prompt" \
            '{question: $q, answer: $a, resume_prompt: $p}')"
fi

marker_file="$RUNNER_DIR/$id.exit"
wrapper="$RUNNER_DIR/$id.wrap"
cat > "$wrapper" <<WRAP
#!/usr/bin/env bash
cd "$work_dir"
exec > >(tee -a "$log_path") 2>&1
# Export the job id so an in-worker agent can call \`mother await --question
# "..."\` without bookkeeping. Without this, the agent has no clean way to
# discover which job it belongs to.
export MOTHER_JOB_ID="$id"
echo "=== mother job $id starting at \$(date) ==="
echo "=== working dir: \$PWD ==="
echo "=== branch:      $branch ==="
echo "=== agent:       $worker_agent ==="
echo "=== session-id:  $session_id ==="
echo "=== plan:        $resolved_plan_path ==="
echo
# stream-json + verbose gives us a live per-event log (one JSON object per
# line). \`mother logs --follow\` pretty-prints these via mother-stream-pretty;
# the raw file stays authoritative and greppable.
#
# Run claude in the background so we can forward signals to it. Without this,
# a SIGTERM to the wrapper would kill bash and orphan claude — which is the
# failure mode mother's reaper needs to escape when claude refuses to exit
# after emitting its final 'result' event. With the trap in place, a SIGTERM
# to the wrapper unblocks claude (gracefully on a healthy session, after
# SIGKILL escalation from mother-run-job on a wedged one), 'wait' returns
# its real exit code, and the marker file is written normally.
claude_pid=""
_forward_signal() {
    [ -n "\$claude_pid" ] && kill -TERM "\$claude_pid" 2>/dev/null || true
}
trap _forward_signal TERM INT
claude --agent "$worker_agent" --session-id "$session_id" -p "\$(cat "$resolved_plan_path")" --output-format stream-json --verbose &
claude_pid=\$!
# wait may be interrupted by the trap (signal raises EINTR and bash returns
# 128+sig); loop until claude is actually gone before recording its real
# exit code.
rc=0
while :; do
    wait "\$claude_pid" 2>/dev/null
    rc=\$?
    kill -0 "\$claude_pid" 2>/dev/null || break
done
echo "\$rc" > "$marker_file"
WRAP
chmod +x "$wrapper"

nohup bash "$wrapper" >/dev/null 2>&1 &
worker_pid=$!
disown 2>/dev/null || true
_job_update ".worker_pid = $worker_pid"
_append_event "worker_spawned" "$(jq -nc --argjson pid "$worker_pid" --arg sid "$session_id" '{pid: $pid, session_id: $sid}')"

# Reaper tunables. RESULT_GRACE_SECONDS is how long we let the worker linger
# after we observe a top-level "result" event in the stream-json log before
# forcing it down (Layer 1 in the bug report). IDLE_REAP_SECONDS is the
# log-mtime watchdog (Layer 2): if the worker hasn't written a single byte
# in that long, we treat it as wedged regardless of whether we ever saw a
# result. Both knobs default conservatively — five minutes is plenty for
# any sane post-result cleanup, and 30 minutes of total log silence is
# already unusual even for long-running tool calls (claude emits periodic
# system events while waiting on tools).
RESULT_GRACE_SECONDS="${MOTHER_RESULT_GRACE_SECONDS:-300}"
IDLE_REAP_SECONDS="${MOTHER_IDLE_REAP_SECONDS:-1800}"

# _terminate_worker: SIGTERM the wrapper + its direct children, wait up to
# 10s for them to exit, then SIGKILL stragglers. We hit the children
# explicitly because the cancel/reap path has historically just SIGTERM'd
# the wrapper, which would leave a hung claude orphaned (the failure mode
# this bug fix is closing). With the wrapper's signal trap in place, the
# direct kill is mostly belt-and-suspenders, but it's also what saves us
# if the wrapper itself has somehow died.
_terminate_worker() {
    local kids
    kids=$(pgrep -P "$worker_pid" 2>/dev/null || true)
    [ -n "$kids" ] && kill -TERM $kids 2>/dev/null || true
    kill -TERM "$worker_pid" 2>/dev/null || true
    local waited=0
    while kill -0 "$worker_pid" 2>/dev/null && [ "$waited" -lt 10 ]; do
        sleep 1
        waited=$((waited + 1))
    done
    if kill -0 "$worker_pid" 2>/dev/null; then
        kids=$(pgrep -P "$worker_pid" 2>/dev/null || true)
        [ -n "$kids" ] && kill -KILL $kids 2>/dev/null || true
        kill -KILL "$worker_pid" 2>/dev/null || true
    fi
}

# _log_mtime: epoch seconds of the log file's last write, or 0 if missing.
# Wrapped because macOS uses `stat -f %m` and Linux uses `stat -c %Y`.
_log_mtime() {
    [ -f "$log_path" ] || { echo 0; return; }
    stat -f %m "$log_path" 2>/dev/null \
        || stat -c %Y "$log_path" 2>/dev/null \
        || echo 0
}

# Poll for the marker file.
cancel_requested=0
final_result_epoch=0
reaped_reason=""
while [ ! -f "$marker_file" ]; do
    sleep 2

    # Honor cancellation: TERM, grace period, then KILL (handled in the helper).
    if [ "$(jq -r '.cancel_requested // false' "$job_file" 2>/dev/null)" = "true" ]; then
        cancel_requested=1
        _terminate_worker
        break
    fi

    # Honor a system-initiated pause (daemon's quota gate). Same kill path
    # as cancel, but the state transitions to `awaiting` (not cancelled) so
    # the daemon's auto-resume can pick the job back up when the offending
    # window resets. We transition state BEFORE killing the worker so the
    # post-loop short-circuit at line ~470 (the `awaiting` exit path) finds
    # the right state and skips the terminal-transition logic.
    if [ "$(jq -r '.pause_requested // false' "$job_file" 2>/dev/null)" = "true" ]; then
        _pause_reason=$(jq -r '.paused_reason // "system"' "$job_file" 2>/dev/null)
        _pause_resume_at=$(jq -r '.auto_resume_at // 0'    "$job_file" 2>/dev/null)
        _job_update '.state = "awaiting"
            | .question = "Mother paused this job because the quota cap was reached. Auto-resumes when the blocking window resets."
            | .pause_requested = null'
        _append_event "paused_for_quota" \
            "$(jq -nc --arg r "$_pause_reason" --argjson ts "${_pause_resume_at:-0}" \
                '{paused_reason: $r, auto_resume_at: $ts}')"
        _terminate_worker
        break
    fi

    # Live observability. Two things we want to know about *as they happen*,
    # not just after claude exits:
    #   1. The PR URL (so `mother status` reflects the artifact even while
    #      the wrapper is still running). Without this, the bug's
    #      "PR exists but mother shows pr_url: null" symptom persists for
    #      the entire post-result-hang window.
    #   2. The top-level `result` event in the stream-json output. Once we
    #      see it, the agent has emitted its canonical "I'm done" signal —
    #      from here on, mother is the timekeeper for how long the wrapper
    #      gets to gracefully wind down.
    if [ -f "$log_path" ]; then
        if [ -z "$(jq -r '.pr_url // empty' "$job_file" 2>/dev/null)" ]; then
            _live_pr_url=$(grep -Eo 'https://github\.com/[^/]+/[^/]+/pull/[0-9]+' "$log_path" 2>/dev/null | tail -1 || true)
            if [ -n "$_live_pr_url" ]; then
                _job_update ".pr_url = \"$_live_pr_url\""
                _append_event "pr_opened" "$(jq -nc --arg url "$_live_pr_url" '{url: $url}')"
            fi
        fi

        if [ "$final_result_epoch" -eq 0 ]; then
            # stream-json emits one complete JSON event per line. The result
            # event has top-level "type":"result". The whitespace tolerance
            # below is paranoia — claude's SDK currently emits compact JSON,
            # but stream formatters change.
            if grep -Eq '"type"[[:space:]]*:[[:space:]]*"result"' "$log_path" 2>/dev/null; then
                final_result_epoch=$(date +%s)
                _job_update ".final_result_at = \"$(iso_now)\""
                _append_event "final_result_observed" "{}"
            fi
        fi
    fi

    # Layer 1 — result observed + grace window expired. The worker has
    # signalled completion and then sat idle past the patience threshold;
    # force it down and treat the job as succeeded (with metadata noting
    # we had to reap).
    if [ "$final_result_epoch" -gt 0 ]; then
        _now_epoch=$(date +%s)
        if [ $((_now_epoch - final_result_epoch)) -ge "$RESULT_GRACE_SECONDS" ]; then
            reaped_reason="result_grace_expired"
            _append_event "reaping_after_result_grace" "$(jq -nc --argjson grace "$RESULT_GRACE_SECONDS" '{grace_seconds: $grace}')"
            _terminate_worker
            break
        fi
    fi

    # Layer 2 — log has been silent past the idle threshold. Catches the
    # "claude hung BEFORE emitting result" case that Layer 1 can't see.
    # Without a result event we don't know whether the work artifact
    # exists, so the final transition will mark this `failed`.
    _mtime=$(_log_mtime)
    if [ "$_mtime" -gt 0 ]; then
        _now_epoch=$(date +%s)
        if [ $((_now_epoch - _mtime)) -ge "$IDLE_REAP_SECONDS" ]; then
            reaped_reason="idle_timeout"
            _append_event "reaping_after_idle_timeout" "$(jq -nc --argjson seconds "$IDLE_REAP_SECONDS" --argjson last_activity "$_mtime" '{idle_seconds: $seconds, last_activity_epoch: $last_activity}')"
            _terminate_worker
            break
        fi
    fi
done

exit_code=0
[ -f "$marker_file" ] && exit_code=$(cat "$marker_file")

# Best-effort: extract a PR URL from the log if we didn't already pick it up
# during the poll loop. Skipped if pr_url was already recorded — re-emitting
# `pr_opened` would double-count in the event trail.
pr_url=$(jq -r '.pr_url // empty' "$job_file" 2>/dev/null)
if [ -z "$pr_url" ] && [ -f "$log_path" ]; then
    pr_url=$(grep -Eo 'https://github\.com/[^/]+/[^/]+/pull/[0-9]+' "$log_path" | tail -1 || true)
    if [ -n "$pr_url" ]; then
        _job_update ".pr_url = \"$pr_url\""
        _append_event "pr_opened" "$(jq -nc --arg url "$pr_url" '{url: $url}')"
    fi
fi

# Release main-dir lock if we took one.
if [ "$isolation" = "main-dir" ]; then
    lock_release "${repo}:workspace" >/dev/null 2>&1 || true
fi

# If the worker called `mother await` and transitioned the job to
# `awaiting` before exiting, respect that. The job is paused (not done) and
# `mother resume` will spawn a fresh worker later — we just need to release
# our own resources cleanly without touching state. The main-dir workspace
# lock was already released above, so the resumed worker can re-acquire it.
current_state=$(jq -r '.state' "$job_file" 2>/dev/null)
if [ "$current_state" = "awaiting" ]; then
    _append_event "worker_exited_paused" \
        "$(jq -nc --arg pr "${pr_url:-}" '{pr_url: $pr}')"
    rm -f "$marker_file" "$wrapper" "$spawn_prompt"
    # The runner_died_early trap only fires while state == "running"; awaiting
    # is safe by virtue of that, but disarm anyway for clarity.
    trap - EXIT
    echo "job $id paused (awaiting input)"
    exit 0
fi

# Verify the artifact: when we're about to mark `succeeded` but didn't
# capture a pr_url during the run, sanity-check that the branch was at
# least pushed to origin. Worktree jobs are spun off on a fresh branch
# whose implicit contract is "the work is shipped to that branch on
# origin." Trusting the `result` event alone (even with subtype=success)
# is how we ended up calling jobs succeeded after the agent yielded
# mid-work — e.g. when an agent uses `Monitor` to wait for lint and ends
# its turn expecting a follow-up turn that `claude -p` never delivers.
#
# Returns 0 to allow the caller to transition to succeeded; returns 1
# after having transitioned to failed itself, in which case the caller
# must NOT also transition.
_verify_artifact_or_fail() {
    # If a pr_url was captured (live or post-loop), the artifact is real.
    [ -z "${pr_url:-}" ] || return 0
    # Only worktree jobs carry the "branch must be on origin" contract.
    # main-dir jobs share a workspace and can't be verified this way.
    [ "$isolation" = "worktree" ] || return 0
    [ -d "$work_dir" ] || return 0  # worktree gone — don't fail spuriously

    if (cd "$work_dir" && git ls-remote --exit-code origin "$branch" >/dev/null 2>&1); then
        # Branch on origin — work shipped to remote, just no PR opened.
        # Probably still a success (some workflows push without opening
        # a PR; some PR-opening tools fail silently after the push). Note
        # it on the events trail so an operator can decide whether to open
        # the PR by hand.
        _append_event "no_pr_url_but_branch_pushed" \
            "$(jq -nc --arg b "$branch" '{branch: $b}')"
        return 0
    fi

    # Branch is NOT on origin → nothing was pushed → work didn't ship,
    # regardless of what the result event claimed. Gather context that'll
    # help the operator decide whether to retry or hand-finish.
    local commits_ahead=0 uncommitted=0
    commits_ahead=$(cd "$work_dir" && git rev-list --count "$base_ref..HEAD" 2>/dev/null || echo 0)
    uncommitted=$(cd "$work_dir" && git status --porcelain 2>/dev/null | wc -l | tr -d ' ')

    _transition failed "$(jq -nc \
        --arg b "$branch" \
        --arg base "$base_ref" \
        --argjson commits "${commits_ahead:-0}" \
        --argjson uncommitted "${uncommitted:-0}" \
        '{
            reason: "no_pr_no_push",
            branch: $b,
            base_ref: $base,
            local_commits_ahead_of_base: $commits,
            uncommitted_files: $uncommitted,
            note: "agent emitted result event but never pushed the branch; work is not on origin"
        }')"
    return 1
}

# Final transition.
if [ "$cancel_requested" -eq 1 ]; then
    _transition cancelled "$(jq -nc '{reason: "user"}')"
elif [ -n "$reaped_reason" ]; then
    # We forced the worker down via one of the reap heuristics. If we'd
    # already observed the agent's final `result` event by then, the work
    # is complete and the worker just refused to exit — call it succeeded
    # with a note (subject to artifact verification). If we reaped without
    # ever seeing a result (idle timeout mid-work), the outcome is
    # indeterminate; mark failed so the operator notices.
    if [ "$final_result_epoch" -gt 0 ]; then
        if _verify_artifact_or_fail; then
            _transition succeeded "$(jq -nc --arg pr "$pr_url" --arg reason "$reaped_reason" '{pr_url: $pr, reaped: $reason}')"
        fi
    else
        _transition failed "$(jq -nc --arg reason "$reaped_reason" '{reason: $reason}')"
    fi
elif [ "$exit_code" = "0" ]; then
    if _verify_artifact_or_fail; then
        _transition succeeded "$(jq -nc --arg pr "$pr_url" '{pr_url: $pr}')"
    fi
else
    _transition failed "$(jq -nc --argjson code "$exit_code" '{exit_code: $code}')"
fi

rm -f "$marker_file" "$wrapper"
# Clean exit — disarm the runner_died_early safety net.
trap - EXIT
echo "job $id finished: $(jq -r .state "$job_file")"
