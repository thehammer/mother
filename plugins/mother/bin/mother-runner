#!/usr/bin/env bash

# --- mother plugin path resolver (prepended during port) ---
# Resolves symlinks so the plugin works when installed via `ln -s` into a bin dir.
_MOTHER_RAW="${BASH_SOURCE[0]}"
while [ -L "$_MOTHER_RAW" ]; do
    _link="$(readlink "$_MOTHER_RAW")"
    case "$_link" in
        /*) _MOTHER_RAW="$_link" ;;
        *)  _MOTHER_RAW="$(dirname "$_MOTHER_RAW")/$_link" ;;
    esac
done
_MOTHER_SELF="$(cd "$(dirname "$_MOTHER_RAW")" && pwd -P)"
: "${MOTHER_BIN_DIR:=$_MOTHER_SELF}"
: "${MOTHER_LIB_DIR:=$_MOTHER_SELF/../lib}"
# -----------------------------------------------------------

# mother-runner — long-lived daemon for the Claude Code background queue.
#
# Polls ${MOTHER_ROOT:-$HOME/.mother}/jobs every MOTHER_POLL_INTERVAL seconds. Promotes
# queued → ready when dependencies are satisfied, and forks `mother-run-job`
# children up to MOTHER_CONCURRENCY in parallel. Reaps exited children each
# tick. On SIGTERM/SIGINT, stops accepting new work and waits up to
# MOTHER_SHUTDOWN_GRACE seconds for in-flight jobs before exiting.
#
# On startup, any jobs in `running` state whose worker pid is gone are marked
# failed with reason=runner_died (crash recovery). Jobs whose worker is still
# alive are left alone (no re-adoption). Legacy records without `worker_pid`
# fall back to matching a recorded `tmux_window` against live tmux windows.
#
# Starts typically via `mother daemon start`. See also `mother daemon stop|status`.

set -u

# shellcheck source=/dev/null
source "$MOTHER_LIB_DIR/state.sh"

MOTHER_CONCURRENCY="${MOTHER_CONCURRENCY:-2}"
MOTHER_POLL_INTERVAL="${MOTHER_POLL_INTERVAL:-2}"
MOTHER_SHUTDOWN_GRACE="${MOTHER_SHUTDOWN_GRACE:-30}"
MOTHER_ARCHIVE_INTERVAL="${MOTHER_ARCHIVE_INTERVAL:-3600}"   # seconds between retention sweeps
MOTHER_ARCHIVE_OLDER_THAN="${MOTHER_ARCHIVE_OLDER_THAN:-30}" # days

PIDFILE="$RUNNER_DIR/runner.pid"
CHILDREN_DIR="$RUNNER_DIR/children"
mkdir -p "$CHILDREN_DIR"

SHUTDOWN=0

# ---------- primitives ----------

_log() {
    printf '[%s] %s\n' "$(_iso_now)" "$*" >&2
}

_write_pidfile() {
    local tmp="$PIDFILE.tmp.$$"
    echo $$ > "$tmp" && mv "$tmp" "$PIDFILE"
}

_remove_pidfile() {
    rm -f "$PIDFILE"
}

_on_signal() {
    SHUTDOWN=1
    _log "signal received — draining"
}

# ---------- child tracking ----------

_track_child() {
    local pid="$1" job_id="$2"
    jq -nc --argjson pid "$pid" --arg job_id "$job_id" --arg started "$(_iso_now)" \
        '{pid: $pid, job_id: $job_id, started_at: $started}' \
        > "$CHILDREN_DIR/$pid.json"
}

_reap_children() {
    # For each tracked child, remove its file if the pid is dead.
    local f pid
    for f in "$CHILDREN_DIR"/*.json; do
        [ -f "$f" ] || continue
        pid=$(basename "$f" .json)
        if ! kill -0 "$pid" 2>/dev/null; then
            rm -f "$f"
        fi
    done
}

_count_running_children() {
    find "$CHILDREN_DIR" -maxdepth 1 -name '*.json' -type f 2>/dev/null | wc -l | tr -d ' '
}

# Supervisor liveness check, used by the reaper to avoid racing the
# in-process supervisor's terminal transition. CHILDREN_DIR tracks the
# mother-run-job (supervisor) PIDs along with the job_id they own; the
# job json's `worker_pid` is a different process — the wrapper bash that
# runs claude. The wrapper exits when claude exits (natural completion),
# leaving the supervisor in a post-exit window: it has to wake from its
# 2s poll-loop sleep, read the marker file, scan for pr_url, and write
# the terminal transition. Reaping based on `worker_pid` alone fires
# during that window and clobbers the supervisor's pending succeeded
# write — sometimes leaving the job stuck in `failed: runner_died`
# despite the work being committed.
_supervisor_alive_for_job() {
    local job_id="$1" f pid jid
    for f in "$CHILDREN_DIR"/*.json; do
        [ -f "$f" ] || continue
        pid="$(basename "$f" .json)"
        jid="$(jq -r '.job_id // empty' "$f" 2>/dev/null)"
        if [ "$jid" = "$job_id" ] && kill -0 "$pid" 2>/dev/null; then
            return 0
        fi
    done
    return 1
}

# ---------- ready-job selection ----------

_pick_next_ready() {
    find "$JOBS_DIR" -maxdepth 1 -name '*.json' -type f 2>/dev/null | while read -r f; do
        jq -r 'select(.state == "ready") | .created_at + "\t" + .id' "$f"
    done | sort | head -1 | cut -f2
}

# ---------- spawning ----------

_spawn_job() {
    local job_id="$1"

    # Pre-transition ready → running so the next poll tick doesn't re-pick
    # this job. mother-run-job tolerates both ready and running as starting
    # states. If the fork fails, the job stays `running` with no tmux window;
    # the next daemon restart's orphan recovery will mark it failed.
    _job_transition "$job_id" running '{"spawned_by":"daemon"}'

    # Detach via nohup + background + stdin/out/err redirection. mother-run-job
    # tees its own log. macOS has no setsid, and nohup + disown is sufficient:
    # signals to the daemon will not cascade once we disown the child.
    nohup "$MOTHER_BIN_DIR/mother-run-job" "$job_id" </dev/null >/dev/null 2>&1 &
    local pid=$!
    disown 2>/dev/null || true
    _track_child "$pid" "$job_id"
    _log "spawned job $job_id as pid $pid"
}

# ---------- crash recovery ----------

_recover_orphans() {
    # Primary check: `worker_pid` + `kill -0`. Falls back to a tmux-window
    # match for legacy job records (created before the headless-worker
    # migration) that recorded `tmux_window` instead of `worker_pid`.
    #
    # $1: grace_seconds (default 0). For jobs with no `worker_pid`, only
    # act if `started_at` is older than this threshold — prevents racing
    # with a live mother-run-job that hasn't persisted worker_pid yet.
    # Startup passes 0 (aggressive); periodic calls from the loop pass a
    # non-zero grace so healthy in-flight supervisors are left alone.
    #
    # Honors `cancel_requested`: when a zombie is reaped and the user had
    # asked to cancel, transition to `cancelled` instead of `failed` so
    # `mother cancel` is effective even when the supervisor is dead.
    local grace="${1:-0}"
    local windows=""
    if command -v tmux >/dev/null 2>&1; then
        windows=$(tmux list-windows -a -F '#W' 2>/dev/null || echo "")
    fi

    local now_epoch; now_epoch=$(date +%s)
    local f state pid window id started_at started_at_sec started_epoch cancel_req
    local terminal_state terminal_reason
    for f in "$JOBS_DIR"/*.json; do
        [ -f "$f" ] || continue
        state=$(jq -r '.state' "$f" 2>/dev/null) || continue
        [ "$state" = "running" ] || continue
        id=$(jq -r '.id' "$f")
        pid=$(jq -r '.worker_pid // empty' "$f")
        window=$(jq -r '.tmux_window // ""' "$f")
        cancel_req=$(jq -r '.cancel_requested // false' "$f")

        # Resolve the terminal state we'd transition to. If the user asked
        # to cancel and the supervisor can't honor it (dead/absent pid),
        # 'cancelled' is more truthful than 'failed: runner_died'.
        if [ "$cancel_req" = "true" ]; then
            terminal_state="cancelled"
            terminal_reason='{"reason":"user"}'
        else
            terminal_state="failed"
            terminal_reason='{"reason":"runner_died"}'
        fi

        if [ -n "$pid" ]; then
            if ! kill -0 "$pid" 2>/dev/null; then
                # Worker is gone, but the supervisor (mother-run-job) may
                # still be in its post-exit window. Reaping here would
                # race the supervisor's terminal transition — see comment
                # on _supervisor_alive_for_job. Defer when supervisor is
                # still alive; only reap when the whole supervision tree
                # is gone.
                if _supervisor_alive_for_job "$id"; then
                    continue
                fi
                _log "marking $id $terminal_state (pid $pid gone; cancel_requested=$cancel_req)"
                _job_transition "$id" "$terminal_state" "$terminal_reason"
            fi
        elif [ -n "$window" ]; then
            # Legacy path: jobs recorded before the headless-worker migration.
            if [ -z "$windows" ]; then
                _log "skipping $id (legacy tmux_window record, no tmux available)"
                continue
            fi
            if ! grep -Fxq "$window" <<< "$windows"; then
                _log "marking $id $terminal_state (window $window gone; cancel_requested=$cancel_req)"
                _job_transition "$id" "$terminal_state" "$terminal_reason"
            fi
        else
            # No worker_pid AND no tmux_window. Supervisor either died before
            # persisting worker_pid, or we're racing a fresh spawn. Apply the
            # grace window: startup reaps immediately (grace=0), the periodic
            # loop waits until started_at is older than grace_seconds.
            if [ "$grace" -gt 0 ]; then
                started_at=$(jq -r '.started_at // empty' "$f")
                [ -n "$started_at" ] || continue
                # Strip fractional seconds — started_at may be either
                # `...SSZ` (from mother-run-job's iso_now) or `...SS.NNNNNNZ`
                # (from state.sh's _iso_now), and date(1) only accepts the
                # former with %S.
                started_at_sec="${started_at%%.*}"
                case "$started_at_sec" in *Z) ;; *) started_at_sec="${started_at_sec}Z" ;; esac
                # ISO8601 → epoch (macOS date needs -j -f; GNU date needs -d).
                started_epoch=$(date -u -j -f "%Y-%m-%dT%H:%M:%SZ" "$started_at_sec" +%s 2>/dev/null \
                    || date -u -d "$started_at_sec" +%s 2>/dev/null || echo 0)
                [ "$started_epoch" -eq 0 ] && continue
                [ $((now_epoch - started_epoch)) -ge "$grace" ] || continue
            fi
            _log "marking $id $terminal_state (no worker_pid or tmux_window; cancel_requested=$cancel_req)"
            _job_transition "$id" "$terminal_state" "$terminal_reason"
        fi
    done
}

# Grace (seconds) before the periodic reaper treats a `running` job with no
# worker_pid as a zombie. Long enough to outlast any reasonable spawn path
# (plan read + lock acquire + wrapper write + nohup fork), short enough that
# users don't stare at a dead job for long.
MOTHER_ORPHAN_GRACE="${MOTHER_ORPHAN_GRACE:-60}"

# ---------- main loop ----------

_maybe_archive() {
    # Run retention at most once per MOTHER_ARCHIVE_INTERVAL seconds, keyed off
    # a timestamp file so it survives restarts.
    local marker="$RUNNER_DIR/last-archive.ts"
    local now last
    now=$(date +%s)
    last=0
    [ -f "$marker" ] && last=$(cat "$marker" 2>/dev/null || echo 0)
    if [ $((now - last)) -ge "$MOTHER_ARCHIVE_INTERVAL" ]; then
        _log "running archive sweep (older-than=${MOTHER_ARCHIVE_OLDER_THAN}d)"
        "$MOTHER_BIN_DIR/mother" archive --older-than "$MOTHER_ARCHIVE_OLDER_THAN" 2>&1 | while read -r line; do _log "archive: $line"; done
        echo "$now" > "$marker"
    fi
}

# ---------- quota-aware dispatch ----------
#
# `_quota_check` (in lib/state.sh) returns 1 when either rolling window
# (5h or 7d) is at or over its operator-set cap. The daemon uses it to:
#
#   1. Auto-resume awaiting jobs whose blocking window has reset
#      (system pauses set `paused_reason: "quota_*"` and `auto_resume_at`;
#      we promote those back to `ready` once both the timestamp has passed
#      and the cache shows quota under cap).
#   2. Refuse to spawn new jobs while over cap (pre-dispatch gate). Jobs
#      stay in `ready` and get retried each tick.
#   3. Pause running jobs that are mid-flight when the cap trips, so
#      headroom returns to the operator's interactive sessions instead of
#      being eaten by background work.
#
# Mid-flight pause exemptions (do NOT pause):
#   - The job already emitted its final `result` event — winding down anyway.
#   - The job is already `awaiting` (paused for some other reason).
#   - The job has `cancel_requested` — operator wants it gone, not preserved.

_auto_resume_check() {
    local now; now=$(date +%s)
    local f state reason resume_at id merged
    for f in "$JOBS_DIR"/*.json; do
        [ -f "$f" ] || continue
        state=$(jq -r '.state // ""' "$f" 2>/dev/null) || continue
        [ "$state" = "awaiting" ] || continue
        reason=$(jq -r '.paused_reason // ""' "$f" 2>/dev/null)
        case "$reason" in quota_*) ;; *) continue ;; esac
        resume_at=$(jq -r '.auto_resume_at // 0' "$f" 2>/dev/null)
        case "$resume_at" in ''|null) resume_at=0 ;; esac
        # Strip fractional seconds defensively.
        resume_at="${resume_at%.*}"
        [ "$resume_at" -gt 0 ] || continue
        [ "$now" -ge "$resume_at" ] || continue
        # Only resume if quota is now actually under cap. The window may
        # have reset on the clock but if we're already pushing the next
        # window (back-to-back heavy use) we should keep waiting.
        if ! _quota_check; then continue; fi
        id=$(jq -r '.id' "$f")
        _log "auto-resuming $id (paused_reason=$reason; resume window has passed)"
        merged=$(jq --arg ts "$(_iso_now)" '
            .state = "ready"
            | .pending_answer = "Quota window has reset — continue from where you left off."
            | .resumed_at = $ts
            | .resume_count = ((.resume_count // 0) + 1)
            | .auto_resume_at = null
            | .paused_reason = null
            | .pause_requested = null
        ' "$f") && _atomic_write "$f" "$merged"
        _append_event "$id" "auto_resumed" \
            "$(jq -nc --arg r "$reason" '{from_paused_reason: $r}')"
    done
}

_maybe_pause_running() {
    # Caller has already verified quota is over cap. Walk currently-tracked
    # children, find their job json, set `pause_requested` + paused_reason
    # + auto_resume_at on the eligible ones. mother-run-job's poll loop
    # picks up `pause_requested` on its next tick and handles the rest
    # (terminate worker, transition state to `awaiting`).
    local reason resume_at
    reason=$(_quota_offending_window)
    [ -n "$reason" ] || return 0
    resume_at=$(_quota_resume_at_for "$reason")
    [ "${resume_at:-0}" -gt 0 ] || return 0

    local f pid job_id job_file fr ar cr pr merged
    for f in "$CHILDREN_DIR"/*.json; do
        [ -f "$f" ] || continue
        pid=$(basename "$f" .json)
        job_id=$(jq -r '.job_id // empty' "$f" 2>/dev/null)
        [ -n "$job_id" ] || continue
        job_file="$JOBS_DIR/$job_id.json"
        [ -f "$job_file" ] || continue
        # Exemptions.
        fr=$(jq -r '.final_result_at // ""' "$job_file" 2>/dev/null)
        [ -n "$fr" ] && continue   # already winding down
        ar=$(jq -r '.state // ""'             "$job_file" 2>/dev/null)
        [ "$ar" = "awaiting" ] && continue
        cr=$(jq -r '.cancel_requested // false' "$job_file" 2>/dev/null)
        [ "$cr" = "true" ] && continue
        pr=$(jq -r '.pause_requested // false'  "$job_file" 2>/dev/null)
        [ "$pr" = "true" ] && continue   # already requested

        merged=$(jq --arg r "$reason" --argjson ts "$resume_at" '
            .pause_requested = true
            | .paused_reason = $r
            | .auto_resume_at = $ts
        ' "$job_file") && _atomic_write "$job_file" "$merged"
        _log "requested pause of $job_id (reason=$reason, resume_at=$resume_at)"
        _append_event "$job_id" "pause_requested" \
            "$(jq -nc --arg r "$reason" --argjson ts "$resume_at" \
                '{paused_reason: $r, auto_resume_at: $ts}')"
    done
}

_loop() {
    while [ "$SHUTDOWN" -eq 0 ]; do
        _reap_children
        _recover_orphans "$MOTHER_ORPHAN_GRACE"
        # Auto-resume system-paused jobs whose window has rolled over
        # BEFORE _promote_ready, so resumed jobs are eligible for the
        # current tick's spawn budget.
        _auto_resume_check
        _promote_ready

        if _quota_check; then
            # Under cap — normal dispatch.
            while [ "$(_count_running_children)" -lt "$MOTHER_CONCURRENCY" ]; do
                local next
                next=$(_pick_next_ready)
                [ -n "$next" ] || break
                _spawn_job "$next"
            done
        else
            # Over cap — hold new dispatches and try to pause anything
            # still running so headroom returns to interactive use.
            _maybe_pause_running
        fi

        _maybe_archive
        # Sleep in short slices so signal handling is responsive.
        local slept=0
        while [ "$slept" -lt "$MOTHER_POLL_INTERVAL" ] && [ "$SHUTDOWN" -eq 0 ]; do
            sleep 1
            slept=$((slept + 1))
        done
    done
}

_drain() {
    _log "drain: waiting up to ${MOTHER_SHUTDOWN_GRACE}s for ${MOTHER_CONCURRENCY} slots to clear"
    local elapsed=0
    while [ "$elapsed" -lt "$MOTHER_SHUTDOWN_GRACE" ]; do
        _reap_children
        local running; running=$(_count_running_children)
        [ "$running" -eq 0 ] && { _log "drain complete"; return 0; }
        sleep 1
        elapsed=$((elapsed + 1))
    done
    _reap_children
    local remaining; remaining=$(_count_running_children)
    if [ "$remaining" -gt 0 ]; then
        _log "drain grace expired — $remaining child(ren) still running; exiting anyway (jobs continue as detached worker processes)"
    fi
}

# ---------- entrypoint ----------

main() {
    _write_pidfile
    trap '_on_signal' TERM INT
    _log "mother-runner started (pid $$, concurrency=$MOTHER_CONCURRENCY, poll=${MOTHER_POLL_INTERVAL}s)"
    _recover_orphans
    _loop
    _drain
    _remove_pidfile
    _log "mother-runner exited"
    exit 0
}

main "$@"
